{
  "name": "verified-orchestration-api",
  "version": "0.0.1",
  "description": "Verified Orchestration platform GraphQL API backend",
  "main": "src/main",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "start": "ts-node --transpile-only -r dotenv/config ./src/main",
    "debug": "ts-node-dev --transpile-only --watch ./src/**/*.graphql,.env -r dotenv/config ./src/main",
    "typeorm": "dotenv -e .env -- ts-node ./node_modules/typeorm/cli.js",
    "db:init-localdev": "dotenv -e .env -- ts-node --transpile-only ./scripts/localdev-database-setup",
    "db:start": "dotenv -e .env -- docker-compose up -d --wait && npm run db:init-localdev",
    "db:stop": "docker-compose stop",
    "db:delete": "docker-compose down",
    "db:reset": "cross-env DATABASE_USERNAME=sa npm run typeorm -- schema:drop --dataSource src/data && npm run db:migrate",
    "db:migration:generate": "cross-env DATABASE_USERNAME=sa ts-node scripts/add-migration.ts generate",
    "db:migration:create": "ts-node scripts/add-migration.ts create",
    "db:migration:check": "npm run typeorm -- migration:generate --dryrun --dataSource src/data --check some/path",
    "db:migrate": "cross-env DATABASE_USERNAME=sa npm run typeorm -- migration:run --dataSource src/data",
    "db:migrate:revert": "cross-env DATABASE_USERNAME=sa npm run typeorm -- migration:revert --dataSource src/data",
    "gql:generate": "graphql-codegen",
    "gql:generate:watch": "graphql-codegen --watch",
    "audit": "npx --yes better-npm-audit audit",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "check-types": "tsc -p tsconfig.build.json --noEmit",
    "check-types:all": "tsc -p tsconfig.json --noEmit",
    "build": "run-s build:*",
    "build:0-clean": "rimraf build",
    "build:1-compile": "tsc -p tsconfig.build.json",
    "build:2-copy-files": "copyfiles -e \"**/*.ts\" \"./src/**/*.graphql\" package.json package-lock.json .npmrc build",
    "build:3-npm-install": "npm ci --prefix build --ignore-scripts --omit=dev && rimraf build/package.json build/package-lock.json build/.npmrc",
    "start:built": "cd build && dotenv -e ../.env node ./src/main && cd ..",
    "test": "jest",
    "test:ci:start-db": "docker-compose up -d && cross-env NODE_ENV=test ts-node scripts/localdev-database-wait",
    "test:ci": "jest --ci --reporters=default --reporters=jest-junit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VerifiedOrchestration/verified-orchestration-api.git"
  },
  "author": "MakerX",
  "bugs": {
    "url": "https://github.com/VerifiedOrchestration/verified-orchestration-api/issues"
  },
  "homepage": "https://github.com/VerifiedOrchestration/verified-orchestration-api#readme",
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript-resolvers": "^4.0.1",
    "@graphql-eslint/eslint-plugin": "^3.20.1",
    "@makerx/eslint-config": "^3.1.0",
    "@makerx/prettier-config": "^2.0.0",
    "@makerx/ts-config": "^1.0.1",
    "@microsoft/microsoft-graph-types": "^2.38.0",
    "@types/config": "^3.3.2",
    "@types/cookie-session": "^2.0.46",
    "@types/cors": "^2.8.15",
    "@types/cross-spawn": "^6.0.4",
    "@types/jest": "^29.5.7",
    "@types/mime-types": "^2.1.3",
    "@types/mssql": "^9.1.2",
    "@types/prompt-sync": "^4.2.2",
    "casual": "^1.6.2",
    "colors": "^1.4.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "cross-spawn": "^7.0.3",
    "dotenv": "^16.3.1",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.52.0",
    "graphql-config": "^5.0.3",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "prompt-sync": "^4.2.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typeorm-extension": "^3.1.1",
    "typescript": "5.2.2"
  },
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@apollo/server-plugin-response-cache": "^4.1.3",
    "@apollo/utils.keyvadapter": "^3.1.0",
    "@apollo/utils.keyvaluecache": "^3.1.0",
    "@azure/identity": "^3.3.2",
    "@azure/msal-node": "^2.4.0",
    "@azure/storage-blob": "^12.16.0",
    "@graphql-codegen/client-preset": "^4.1.0",
    "@graphql-tools/load-files": "^7.0.0",
    "@graphql-tools/merge": "^9.0.0",
    "@graphql-tools/schema": "^10.0.0",
    "@graphql-tools/utils": "^10.0.8",
    "@jenniferplusplus/opentelemetry-instrumentation-bullmq": "^0.3.1",
    "@keyv/redis": "^2.8.0",
    "@makerx/express-bearer": "^1.1.0",
    "@makerx/express-msal": "^1.1.0",
    "@makerx/graphql-apollo-server": "^1.2.0",
    "@makerx/graphql-core": "^2.1.0",
    "@makerx/node-common": "^1.2.0",
    "@makerx/node-winston": "^1.2.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@opentelemetry/api": "^1.6.0",
    "@opentelemetry/instrumentation": "^0.44.0",
    "@opentelemetry/instrumentation-express": "^0.33.2",
    "@opentelemetry/instrumentation-graphql": "^0.35.2",
    "@opentelemetry/instrumentation-ioredis": "^0.35.2",
    "@opentelemetry/instrumentation-tedious": "^0.6.2",
    "@opentelemetry/instrumentation-winston": "^0.32.2",
    "@opentelemetry/sdk-trace-node": "^1.17.1",
    "@opentelemetry/semantic-conventions": "^1.17.1",
    "@sendgrid/mail": "^8.1.0",
    "applicationinsights": "^3.0.0-beta.9",
    "body-parser": "^1.20.2",
    "bullmq": "^4.12.7",
    "config": "^3.3.9",
    "cookie-session": "^2.0.0",
    "cors": "^2.8.5",
    "cross-fetch": "^4.0.0",
    "dataloader": "^2.2.2",
    "date-fns": "^2.30.0",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-middleware": "^6.1.35",
    "graphql-redis-subscriptions": "^2.6.0",
    "graphql-scalars": "^1.22.4",
    "graphql-shield": "^7.6.5",
    "graphql-subscriptions": "^2.0.0",
    "graphql-voyager": "^1.3.0",
    "graphql-ws": "^5.14.2",
    "keyv": "^4.5.4",
    "lodash": "^4.17.21",
    "mime-types": "^2.1.35",
    "mssql": "^9.3.2",
    "opentelemetry-instrumentation-ws": "^0.4.3",
    "typeorm": "^0.3.17",
    "ws": "^8.14.2"
  },
  "jest-junit": {
    "outputName": "test-results.xml",
    "ancestorSeparator": " › ",
    "uniqueOutputName": "false",
    "suiteNameTemplate": "{filepath}",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  }
}
