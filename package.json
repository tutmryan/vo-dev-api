{
  "name": "verified-orchestration-api",
  "version": "0.0.1",
  "description": "Verified Orchestation platform GraphQL API backend",
  "main": "src/main",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "ts-node --transpile-only -r dotenv/config ./src/main",
    "debug": "ts-node-dev --transpile-only --watch ./src/**/*.graphql,.env -r dotenv/config ./src/main",
    "typeorm": "dotenv -e .env -- ts-node ./node_modules/typeorm/cli.js",
    "db:init-localdev": "dotenv -e .env -- ts-node --transpile-only ./scripts/localdev-database-setup",
    "db:start": "dotenv -e .env -- docker-compose up -d --wait && npm run db:init-localdev",
    "db:stop": "docker-compose stop",
    "db:delete": "docker-compose down",
    "db:reset": "cross-env DATABASE_USERNAME=sa npm run typeorm -- schema:drop --dataSource src/data && npm run db:migrate",
    "db:migration:generate": "cross-env DATABASE_USERNAME=sa ts-node scripts/add-migration.ts generate",
    "db:migration:create": "ts-node scripts/add-migration.ts create",
    "db:migration:check": "npm run typeorm -- migration:generate --dryrun --dataSource src/data --check some/path",
    "db:migrate": "cross-env DATABASE_USERNAME=sa npm run typeorm -- migration:run --dataSource src/data",
    "db:migrate:revert": "cross-env DATABASE_USERNAME=sa npm run typeorm -- migration:revert --dataSource src/data",
    "gql:generate": "graphql-codegen",
    "gql:generate:watch": "graphql-codegen --watch",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "check-types": "tsc -p tsconfig.build.json --noEmit",
    "check-types:all": "tsc -p tsconfig.json --noEmit",
    "build": "run-s build:*",
    "build:0-clean": "rimraf build",
    "build:1-compile": "tsc -p tsconfig.build.json",
    "build:2-copy-files": "copyfiles -e \"**/*.ts\" \"./src/schema/*.graphql\" \"./src/features/**/*.graphql\" package.json package-lock.json .npmrc build",
    "build:3-npm-install": "npm ci --prefix build --ignore-scripts --omit=dev && rimraf build/package.json build/package-lock.json build/.npmrc",
    "start:built": "cd build && dotenv -e ../.env node ./src/main && cd ..",
    "test": "jest",
    "test:ci:start-db": "docker-compose up -d && cross-env NODE_ENV=test ts-node scripts/localdev-database-wait",
    "test:ci": "jest --ci --reporters=default --reporters=jest-junit",
    "postintall": "patch-package --yes"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VerifiedOrchestration/verified-orchestration-api.git"
  },
  "author": "MakerX",
  "bugs": {
    "url": "https://github.com/VerifiedOrchestration/verified-orchestration-api/issues"
  },
  "homepage": "https://github.com/VerifiedOrchestration/verified-orchestration-api#readme",
  "devDependencies": {
    "@graphql-codegen/cli": "^3.3.0",
    "@graphql-codegen/typescript-resolvers": "^3.2.0",
    "@graphql-eslint/eslint-plugin": "^3.18.0",
    "@makerx/eslint-config": "^3.0.0",
    "@makerx/prettier-config": "^2.0.0",
    "@makerx/ts-config": "^1.0.1",
    "@microsoft/microsoft-graph-types": "^2.26.0",
    "@types/config": "^3.3.0",
    "@types/cookie-session": "^2.0.44",
    "@types/cors": "^2.8.13",
    "@types/cross-spawn": "^6.0.2",
    "@types/jest": "^29.5.0",
    "@types/mssql": "^8.1.2",
    "@types/prompt-sync": "^4.2.0",
    "casual": "^1.6.2",
    "colors": "^1.4.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "cross-spawn": "^7.0.3",
    "dotenv": "^16.0.3",
    "dotenv-cli": "^7.2.1",
    "eslint": "^8.38.0",
    "graphql-config": "^4.5.0",
    "jest": "^29.5.0",
    "jest-junit": "^15.0.0",
    "npm-run-all": "^4.1.5",
    "patch-package": "^6.5.1",
    "prompt-sync": "^4.2.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typeorm-extension": "^2.7.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@apollo/server": "^4.6.0",
    "@apollo/utils.keyvadapter": "^2.0.2",
    "@apollo/utils.keyvaluecache": "^2.1.1",
    "@azure/identity": "^3.1.3",
    "@azure/msal-node": "^1.17.0",
    "@graphql-codegen/client-preset": "^3.0.0",
    "@graphql-tools/load-files": "^6.6.1",
    "@graphql-tools/merge": "^8.4.0",
    "@graphql-tools/schema": "^9.0.17",
    "@graphql-tools/utils": "^9.2.1",
    "@keyv/redis": "^2.5.7",
    "@makerxstudio/express-bearer": "^0.2.0",
    "@makerxstudio/express-msal": "^1.1.0",
    "@makerxstudio/graphql-apollo-server": "^1.2.0",
    "@makerxstudio/graphql-core": "^0.6.0",
    "@makerxstudio/node-common": "^0.2.4",
    "@makerxstudio/node-winston": "^0.1.1",
    "@microsoft/microsoft-graph-client": "^3.0.5",
    "@opentelemetry/api": "^1.4.1",
    "@opentelemetry/instrumentation-express": "^0.32.1",
    "@opentelemetry/instrumentation-graphql": "^0.34.0",
    "@opentelemetry/instrumentation-http": "^0.37.0",
    "@opentelemetry/instrumentation-tedious": "^0.5.1",
    "@opentelemetry/instrumentation-winston": "^0.31.1",
    "@opentelemetry/sdk-trace-base": "^1.11.0",
    "@opentelemetry/semantic-conventions": "^1.11.0",
    "applicationinsights": "^3.0.0-beta.4",
    "body-parser": "^1.20.2",
    "config": "^3.3.9",
    "cookie-session": "^2.0.0",
    "cors": "^2.8.5",
    "cross-fetch": "^3.1.5",
    "express": "^4.18.2",
    "graphql": "^16.6.0",
    "graphql-middleware": "^6.1.33",
    "graphql-scalars": "^1.21.3",
    "graphql-shield": "^7.6.5",
    "graphql-tools": "^8.3.19",
    "keyv": "^4.5.2",
    "lodash": "^4.17.21",
    "mssql": "^9.1.1",
    "typeorm": "^0.3.14"
  },
  "jest-junit": {
    "outputName": "test-results.xml",
    "ancestorSeparator": " › ",
    "uniqueOutputName": "false",
    "suiteNameTemplate": "{filepath}",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  },
  "overrides": {
    "xml2js": "0.5.0"
  }
}
