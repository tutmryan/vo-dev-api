{
  "name": "verified-orchestration-api",
  "version": "0.0.1",
  "description": "Verified Orchestration platform GraphQL API backend",
  "main": "src/main",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "cross-env NODE_EXTRA_CA_CERTS=./local-dev/cert/127.0.0.1.pem ts-node --transpile-only -r dotenv/config ./src/main.tracing.dev",
    "debug": "cross-env NODE_EXTRA_CA_CERTS=./local-dev/cert/127.0.0.1.pem ts-node-dev --transpile-only --watch ./src/**/*.graphql,.env -r dotenv/config ./src/main.tracing.dev",
    "dev": "run-p gql:generate:watch debug",
    "typeorm": "dotenv -e .env -- ts-node ./node_modules/typeorm/cli.js",
    "db:init-localdev": "dotenv -e .env -- ts-node --transpile-only ./scripts/localdev-database-setup",
    "db:start": "dotenv -e .env -- docker compose up -d --wait && npm run db:init-localdev",
    "db:stop": "docker compose stop",
    "db:delete": "docker compose down",
    "db:reset": "cross-env DATABASE_USERNAME=sa npm run typeorm -- schema:drop --dataSource src/data && npm run db:migrate",
    "db:migration:generate": "cross-env DATABASE_USERNAME=sa ts-node scripts/add-migration.ts generate",
    "db:migration:create": "ts-node scripts/add-migration.ts create",
    "db:migration:check": "npm run typeorm -- migration:generate --dryrun --dataSource src/data --check some/path",
    "db:migrate": "cross-env DATABASE_USERNAME=sa npm run typeorm -- migration:run --dataSource src/data",
    "db:migrate:revert": "cross-env DATABASE_USERNAME=sa npm run typeorm -- migration:revert --dataSource src/data",
    "gql:generate": "graphql-codegen",
    "gql:generate:watch": "graphql-codegen --watch",
    "audit": "npx --yes better-npm-audit audit",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "build": "run-s build:*",
    "build:0-clean": "rimraf build",
    "build:1-compile": "tsc -p tsconfig.build.json",
    "build:2-copy-files": "copyfiles -e \"**/*.ts\" \"./src/**/*.graphql\" \"./src/**/*.ejs\" package.json package-lock.json .npmrc build",
    "build:3-npm-install": "npm ci --prefix build --omit=dev && rimraf build/package.json build/package-lock.json build/.npmrc",
    "start:built": "cd build && dotenv -e ../.env node ./src/main && cd ..",
    "test": "jest",
    "test:ci:start-db": "docker compose up -d && cross-env NODE_ENV=test ts-node scripts/localdev-database-wait",
    "test:ci": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" jest --ci --reporters=default --reporters=jest-junit",
    "start:dev:tunnels": "bun run ./scripts/start-dev-tunnels"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VerifiedOrchestration/verified-orchestration-api.git"
  },
  "author": "MakerX",
  "bugs": {
    "url": "https://github.com/VerifiedOrchestration/verified-orchestration-api/issues"
  },
  "homepage": "https://github.com/VerifiedOrchestration/verified-orchestration-api#readme",
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/typescript-resolvers": "^4.1.0",
    "@graphql-eslint/eslint-plugin": "^3.20.1",
    "@makerx/eslint-config": "^3.1.1",
    "@makerx/prettier-config": "^2.0.1",
    "@makerx/ts-config": "^1.0.1",
    "@microsoft/microsoft-graph-types": "^2.40.0",
    "@parcel/watcher": "^2.4.1",
    "@types/config": "^3.3.4",
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.17",
    "@types/cross-spawn": "^6.0.6",
    "@types/ejs": "^3.1.5",
    "@types/jest": "^29.5.12",
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/mime-types": "^2.1.4",
    "@types/mssql": "^9.1.5",
    "@types/prompt-sync": "^4.2.3",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "bun": "^1.1.32",
    "casual": "^1.6.2",
    "colors": "^1.4.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "cross-spawn": "^7.0.5",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.0",
    "graphql-config": "^5.0.3",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "ngrok": "^5.0.0-beta.2",
    "npm-run-all": "^4.1.5",
    "open": "^8.4.2",
    "open-editor": "^5.0.0",
    "patch-package": "^8.0.0",
    "prettier-2": "npm:prettier@^2",
    "prompt-sync": "^4.2.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm-extension": "^3.5.1",
    "typescript": "5.5.2"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@apollo/utils.keyvaluecache": "^3.1.0",
    "@azure/identity": "^4.3.0",
    "@azure/monitor-opentelemetry": "^1.6.0",
    "@azure/msal-node": "^2.9.2",
    "@azure/storage-blob": "^12.23.0",
    "@escape.tech/graphql-armor": "^3.1.2",
    "@graphql-codegen/client-preset": "^4.3.0",
    "@graphql-tools/load-files": "^7.0.0",
    "@graphql-tools/merge": "^9.0.4",
    "@graphql-tools/schema": "^10.0.4",
    "@graphql-tools/utils": "^10.2.2",
    "@jenniferplusplus/opentelemetry-instrumentation-bullmq": "^0.5.0",
    "@keyv/redis": "^2.8.5",
    "@makerx/express-bearer": "^1.2.0",
    "@makerx/express-msal": "^1.3.0",
    "@makerx/graphql-apollo-server": "^1.4.2",
    "@makerx/graphql-core": "^2.2.2",
    "@makerx/node-common": "^1.5.0",
    "@makerx/node-winston": "^1.2.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.52.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.1",
    "@opentelemetry/instrumentation-express": "^0.40.1",
    "@opentelemetry/instrumentation-graphql": "^0.41.0",
    "@opentelemetry/instrumentation-tedious": "^0.11.0",
    "@opentelemetry/instrumentation-undici": "^0.3.0",
    "@opentelemetry/instrumentation-winston": "^0.38.0",
    "@opentelemetry/sdk-logs": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/semantic-conventions": "^1.25.1",
    "@sendgrid/mail": "^8.1.3",
    "@types/oidc-provider": "^8.5.2",
    "asn1js": "^3.0.5",
    "body-parser": "^1.20.2",
    "bullmq": "^5.40.5",
    "config": "^3.3.11",
    "cookie-session": "^2.1.0",
    "cors": "^2.8.5",
    "cross-fetch": "^4.0.0",
    "dataloader": "^2.2.2",
    "date-fns": "^3.6.0",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "graphql": "^16.9.0",
    "graphql-constraint-directive": "^5.4.3",
    "graphql-middleware": "^6.1.35",
    "graphql-redis-subscriptions": "^2.6.1",
    "graphql-scalars": "^1.23.0",
    "graphql-shield": "^7.6.5",
    "graphql-subscriptions": "^2.0.0",
    "graphql-voyager-1": "npm:graphql-voyager@^1",
    "graphql-ws": "^5.16.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.4",
    "keyv": "^4.5.4",
    "libphonenumber-js": "^1.11.7",
    "lodash": "^4.17.21",
    "mime-types": "^2.1.35",
    "mssql": "^9.3.2",
    "ngrok": "^5.0.0-beta.2",
    "oidc-provider": "^8.5.1",
    "opentelemetry-instrumentation-ws": "^0.5.0",
    "pkijs": "^3.2.4",
    "qrcode": "^1.5.3",
    "rate-limiter-flexible": "^5.0.3",
    "twilio": "^5.2.2",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0",
    "ws": "^8.17.1",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "jest-junit": {
    "outputName": "test-results.xml",
    "ancestorSeparator": " › ",
    "uniqueOutputName": "false",
    "suiteNameTemplate": "{filepath}",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  },
  "overrides": {
    "@azure/identity": "^4.3.0",
    "braces": "^3.0.3",
    "ws": "^8.17.1"
  }
}
