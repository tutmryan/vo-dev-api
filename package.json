{
  "name": "verified-orchestration-api",
  "version": "0.0.1",
  "description": "Verified Orchestation platform GraphQL API backend",
  "main": "src/main",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "echo \"Error: no tests yet\"",
    "start": "ts-node --transpile-only -r dotenv/config ./src/main",
    "debug": "ts-node-dev --transpile-only --watch ./src/**/*.graphql,.env,./config/*.json -r dotenv/config ./src/main",
    "typeorm": "dotenv -e .env -- ts-node ./node_modules/typeorm/cli.js",
    "db:start": "dotenv -e .env -- docker-compose up -d",
    "db:stop": "docker-compose stop",
    "db:delete": "docker-compose down",
    "db:reset": "cross-env DATABASE_USERNAME=admin npm run typeorm -- schema:drop --dataSource src/data && npm run db:migrate",
    "db:migration:generate": "cross-env DATABASE_USERNAME=admin ts-node scripts/add-migration.ts generate",
    "db:migration:create": "ts-node scripts/add-migration.ts create",
    "db:migration:check": "npm run typeorm -- migration:generate --dryrun --dataSource src/data --check some/path",
    "db:migrate": "cross-env DATABASE_USERNAME=admin npm run typeorm -- migration:run --dataSource src/data",
    "db:migrate:revert": "cross-env DATABASE_USERNAME=admin npm run typeorm -- migration:revert --dataSource src/data",
    "gql:generate": "graphql-codegen",
    "gql:generate:watch": "graphql-codegen --watch",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "check-types": "tsc --noEmit",
    "build": "run-s build:*",
    "build:0-clean": "rimraf build",
    "build:1-compile": "tsc -p tsconfig.build.json",
    "build:2-copy-files": "copyfiles -e \"**/*.ts\" \"./config/*.json\" \"./src/schema/*.graphql\" \"./src/features/**/*.graphql\" package.json package-lock.json .npmrc build",
    "build:3-npm-install": "npm ci --prefix build --ignore-scripts --omit=dev && rimraf build/package.json build/package-lock.json build/.npmrc",
    "start:built": "cd build && dotenv -e ../.env node ./src/index && cd .."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VerifiedOrchestration/verified-orchestration-api.git"
  },
  "author": "MakerX",
  "bugs": {
    "url": "https://github.com/VerifiedOrchestration/verified-orchestration-api/issues"
  },
  "homepage": "https://github.com/VerifiedOrchestration/verified-orchestration-api#readme",
  "devDependencies": {
    "@graphql-codegen/cli": "^3.2.1",
    "@graphql-codegen/typescript-resolvers": "^3.1.0",
    "@graphql-eslint/eslint-plugin": "^3.16.1",
    "@makerx/eslint-config": "^3.0.0",
    "@makerx/prettier-config": "^2.0.0",
    "@makerx/ts-config": "^1.0.1",
    "@types/config": "^3.3.0",
    "@types/cookie-session": "^2.0.44",
    "@types/cors": "^2.8.13",
    "@types/prompt-sync": "^4.2.0",
    "colors": "^1.4.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.3",
    "dotenv-cli": "^7.0.0",
    "eslint": "^8.35.0",
    "graphql-config": "^4.5.0",
    "npm-run-all": "^4.1.5",
    "prompt-sync": "^4.2.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typeorm-extension": "^2.5.2",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@apollo/server": "^4.4.1",
    "@azure/msal-node": "^1.15.0",
    "@graphql-tools/load-files": "^6.6.1",
    "@graphql-tools/merge": "^8.4.0",
    "@graphql-tools/schema": "^9.0.17",
    "@graphql-tools/utils": "^9.2.1",
    "@makerxstudio/express-bearer": "^0.2.0",
    "@makerxstudio/express-msal": "^1.1.0",
    "@makerxstudio/graphql-apollo-server": "^1.2.0",
    "@makerxstudio/graphql-core": "^0.6.0",
    "@makerxstudio/node-common": "^0.1.1",
    "@makerxstudio/node-winston": "^0.1.1",
    "config": "^3.3.9",
    "cookie-session": "^2.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "graphql": "^16.6.0",
    "graphql-middleware": "^6.1.33",
    "graphql-scalars": "^1.20.1",
    "graphql-shield": "^7.6.5",
    "graphql-tools": "^8.3.19",
    "mssql": "^7.3.5",
    "typeorm": "^0.3.12"
  },
  "overrides": {
    "jsonwebtoken": "9.0.0"
  }
}
