{
  "name": "docs-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "build:pr": "npm run generate-graphql-docs && npx --yes cross-env GRAPHQL_ENDPOINT=https://ci-graphql-endpoint ADMIN_URL=https://ci-admin-url PORTAL_URL=https://ci-portal-url npm run docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "audit": "npx --yes better-npm-audit audit",
    "check-types": "tsc",
    "generate-graphql-docs": "rimraf ./docs/reference/default.md && docusaurus graphql-to-doc && rimraf ./docs/reference/generated.md && git checkout -- ./docs/reference/sidebar-schema.js",
    "generate-graphql-docs:watch": "nodemon -e graphql -w ../src/ -x npm run generate-graphql-docs",
    "delete-graphql-docs": "git clean -fdx -- ./docs/reference && git checkout -- ./docs/reference/default.md",
    "graphql-inspector": "graphql-inspector"
  },
  "dependencies": {
    "@docusaurus/core": "3.4.0",
    "@docusaurus/preset-classic": "3.4.0",
    "@easyops-cn/docusaurus-search-local": "^0.45.0",
    "@graphql-markdown/docusaurus": "^1.24.2",
    "@graphql-tools/graphql-file-loader": "^8.0.1",
    "@mdx-js/react": "^3.0.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.4.0",
    "@docusaurus/tsconfig": "3.4.0",
    "@docusaurus/types": "3.4.0",
    "@graphql-inspector/cli": "^5.0.6",
    "dotenv": "^16.4.5",
    "typescript": "^5.5.2",
    "nodemon": "^3.1.4"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "overrides": {
    "braces": "^3.0.3",
    "ws": "^8.17.1"
  }
}
