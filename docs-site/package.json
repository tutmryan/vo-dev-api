{
  "name": "docs-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "build:pr": "npm run generate-graphql-docs && npx --yes cross-env GRAPHQL_ENDPOINT=https://ci-graphql-endpoint ADMIN_URL=https://ci-admin-url npm run docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "check-types": "tsc",
    "generate-graphql-docs": "rimraf ./docs/reference/default.md && docusaurus graphql-to-doc && rimraf ./docs/reference/generated.md && git checkout -- ./docs/reference/sidebar-schema.js",
    "delete-graphql-docs": "git clean -fdx -- ./docs/reference && git checkout -- ./docs/reference/default.md",
    "graphql-inspector": "graphql-inspector"
  },
  "dependencies": {
    "@docusaurus/core": "3.1.0",
    "@docusaurus/preset-classic": "3.1.0",
    "@graphql-markdown/docusaurus": "^1.22.0",
    "@graphql-tools/graphql-file-loader": "^8.0.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^1.3.5",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.1.0",
    "@graphql-inspector/cli": "^4.0.3",
    "@docusaurus/tsconfig": "3.1.0",
    "@docusaurus/types": "3.1.0",
    "dotenv": "^16.3.1",
    "typescript": "^5.3.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
