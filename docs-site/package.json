{
  "name": "docs-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "start:dev": "concurrently -n builder,graphql,roles -c green,blue,yellow \"docusaurus start --host 0.0.0.0 --no-open\" \"nodemon -e graphql -w ../src/generated/schema.json -x docusaurus graphql-to-doc \" \"npm run generate-permissions-docs\"",
    "prebuild": "npm run generate-graphql-docs && npm run generate-permissions-docs",
    "build": "docusaurus build",
    "build:pr": "npx --yes cross-env GRAPHQL_ENDPOINT=https://ci-graphql-endpoint ADMIN_URL=https://ci-admin-url PORTAL_URL=https://ci-portal-url npm run build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "audit": "npx --yes better-npm-audit audit",
    "check-types": "tsc",
    "generate-graphql-docs": "docusaurus graphql-to-doc && rimraf ./api-reference/generated.md",
    "generate-graphql-docs:watch": "nodemon -e graphql -w ../src/ -x npm run generate-graphql-docs",
    "delete-graphql-docs": "git clean -fdx -- ./api-reference",
    "graphql-inspector": "graphql-inspector",
    "generate-permissions-docs": "tsx scripts/generate-permissions-docs.ts"
  },
  "dependencies": {
    "@docusaurus/core": "^3.8.1",
    "@docusaurus/plugin-content-blog": "^3.8.1",
    "@docusaurus/preset-classic": "^3.8.1",
    "@easyops-cn/docusaurus-search-local": "^0.45.0",
    "@graphql-markdown/docusaurus": "^1.24.2",
    "@graphql-tools/json-file-loader": "^8.0.20",
    "@mdx-js/react": "^3.0.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.8.1",
    "@docusaurus/tsconfig": "3.4.0",
    "@docusaurus/types": "3.4.0",
    "@graphql-inspector/cli": "^5.0.6",
    "concurrently": "^9.2.0",
    "dotenv": "^16.4.5",
    "nodemon": "^3.1.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.5.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "overrides": {
    "braces": "^3.0.3",
    "ws": "^8.17.1"
  }
}
