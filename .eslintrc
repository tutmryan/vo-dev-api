{
  "root": true,
  "env": {
    "node": true
  },
  "extends": ["@makerx/eslint-config"],

  "overrides": [
    {
      "files": ["*.graphql"],
      "extends": "plugin:@graphql-eslint/schema-recommended",
      "rules": {
        // "@graphql-eslint/strict-id-in-types": ["error", { "exceptions": { "suffixes": ["Paged"] } }]
      }
    },
    {
      "files": ["*.ts"],
      "excludedFiles": ["src/**/testing.ts", "src/**/*.test.ts", "src/**/test.ts"],
      "rules": {
        "@typescript-eslint/no-unnecessary-condition": "error",
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-non-null-assertion": "off",
        "@typescript-eslint/consistent-type-imports": "error"
      },
      "parserOptions": {
        "project": ["./tsconfig.json"]
      }
    }
  ],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "config",
            "message": "Do not use untyped config, import from src/config instead"
          }
        ]
      }
    ]
  }
}
