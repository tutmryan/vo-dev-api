{
  "extends": "@makerx/ts-config",
  "compilerOptions": {
    // https://github.com/microsoft/TypeScript/wiki/Node-Target-Mapping
    "target": "ES2022",
    "lib": ["ES2023"],
    "outDir": "./build",
    "rootDir": ".",
    "esModuleInterop": true,
    "noUncheckedIndexedAccess": true,
    "useDefineForClassFields": false, // required for typeorm decorator fields to work properly, as per ES2021 behavior
    "types": ["jest", "node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "files": ["src/express.d.ts"],
  "include": ["src", "config", "test", "scripts", "migrate-db", "jest.*.ts"],
  "exclude": ["src/features/oidc-provider/oidc-ui/**"]
}
