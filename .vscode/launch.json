{
  "configurations": [
    {
      "name": "Launch API",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "debug"],
      "cwd": "${workspaceRoot}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "node_modules/**"],
      "smartStep": true
    },
    {
      "name": "Attach to API",
      "type": "node",
      "port": 4010,
      "request": "attach",
      "restart": true,
      "remoteRoot": "/app",
      "localRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "smartStep": true
    },
    {
      "name": "Migrate DB package",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceRoot}/migrate-db",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "node_modules/**"],
      "smartStep": true
    },
    {
      "name": "Download remote schema",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "gql:download-remote"],
      "cwd": "${workspaceRoot}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "node_modules/**"],
      "smartStep": true
    }
  ]
}
