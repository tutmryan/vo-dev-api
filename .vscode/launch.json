{
  "configurations": [
    {
      "name": "API",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run debug"
    },
    {
      "name": "API (migrate)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run debug",
      "preLaunchTask": "Migrate DB"
    },
    {
      "name": "Migrate Database",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start",
      "cwd": "${workspaceFolder}/migrate-db-lambda"
    },
    {
      "name": "Generate GraphQL Types (watch)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run gql:generate:watch"
    },
    {
      "name": "Build API",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run build"
    },
    {
      "name": "Run built API",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start:built"
    }
  ],
  "compounds": [
    {
      "name": "API + Codegen",
      "configurations": ["API", "Generate GraphQL Types (watch)"],
      "stopAll": true
    }
  ]
}
