{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start DB",
      "type": "npm",
      "script": "db:start",
      "path": "${workspaceFolder}",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Migrate DB",
      "type": "npm",
      "script": "db:migrate",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "dependsOn": ["Start DB"]
    },
    {
      "label": "Revert last DB migration",
      "type": "npm",
      "script": "db:migrate:revert",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "dependsOn": ["Start DB"]
    },
    {
      "label": "Reset DB",
      "type": "npm",
      "script": "db:reset",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "dependsOn": ["Start DB"]
    },
    {
      "label": "Generate GraphQL Types",
      "type": "npm",
      "script": "gql:generate",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Generate GraphQL Types (watch)",
      "type": "npm",
      "script": "gql:generate:watch",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Check types",
      "type": "npm",
      "script": "check-types",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Lint",
      "type": "npm",
      "script": "lint",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Test",
      "type": "npm",
      "script": "test",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build",
      "type": "npm",
      "script": "build",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Start built",
      "type": "npm",
      "script": "start:built",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Start dev tunnels",
      "type": "npm",
      "script": "start:dev:tunnels",
      "path": "${workspaceFolder}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
