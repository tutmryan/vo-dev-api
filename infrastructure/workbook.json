            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "traces\n| where isnotnull(customDimensions.issuance)\n| extend Service = customDimensions.service\n| extend Issuance = todynamic(tostring(customDimensions.issuance))\n| extend Id = Issuance.id\n| extend IdentityId = Issuance.identityId\n| extend ContractId = Issuance.contractId\n| extend IssuedById = Issuance.issuedById\n| project\n timestamp,\n message,\n Id,\n IdentityId,\n ContractId,\n IssuedById,\n Issuance,\n customDimensions\n",
              "size": 0,
