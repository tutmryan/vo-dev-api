        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "traces\n| where message has 'API GraphQL'\n| extend query = extract('(query|mutation) (\\\\w*)', 2, tostring(customDimensions.query), typeof(string))\n| extend duration = toint(customDimensions.duration)\n| where query != ''\n| summarize count(), round(avg(duration)), percentiles(duration, 50, 95, 99) by query\n| order by percentile_duration_99 desc\n\n",
              "size": 1,
              "showAnalytics": true,
              "title": "GraphQL operation duration",
              "timeContextFromParameter": "Timerange",
              "showRefreshButton": true,
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.insights/components"
            },
            "name": "GraphQL operation duration",
            "styleSettings": {
              "showBorder": true
            }
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "dependencies\n| where type == 'SQL'\n| extend query = extract('/\\\\* (.+?) \\\\*/', 1, data, typeof(string))\n| where query != ''\n| summarize count(), round(avg(duration)), percentiles(round(duration), 50, 95, 99) by query\n| order by percentile_duration_99\n",
              "size": 0,
              "showAnalytics": true,
              "title": "SQL operation duration",
