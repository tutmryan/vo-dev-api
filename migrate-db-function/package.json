{
  "name": "@makerx/migrate-db-function",
  "version": "1.0.0",
  "description": "Run TypeORM migrations",
  "author": "MakerX",
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "npm run clean && tsc && npm run build:copy-files && npm run build:install && npm run build:post-build",
    "clean": "rimraf build",
    "build:copy-files": "copyfiles \"package*.json\" \"**/function.json\" host.json build",
    "build:install": "npm ci --omit=dev --prefix build",
    "build:post-build": "rimraf build/package.json build/package-lock.json"
  },
  "devDependencies": {
    "@azure/functions": "^3.5.1",
    "@tsconfig/node18": "^1.0.1",
    "@types/node": "^18.15.11",
    "copyfiles": "^2.4.1",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "mssql": "^9.1.1",
    "typeorm": "^0.3.14"
  },
  "overrides": {
    "xml2js": "0.5.0"
  }
}
