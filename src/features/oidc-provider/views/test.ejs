<div class="alert alert-info d-flex align-items-center" role="alert">
  <div class="spinner-border spinner-border-md text-primary me-3" role="status"></div>
  <div class="fw-light">
    Something is happening...
  </div>
</div>

<div class="alert alert-success d-flex align-items-center" role="alert">
  <div class="spinner-border spinner-border-md text-primary me-3" role="status"></div>
  <div class="fw-light">
    Presentation received.
    <br />Signing you in...
  </div>
  <div class="ms-auto"></div>
  <div class="text-success me-3"><i class="bi-check2-all text-success" style="font-size: 2rem;"></i></div>
</div>

<div class="alert alert-danger d-flex align-items-center" role="alert">
  <div class="text-primary me-3"><i class="bi-exclamation-circle text-danger" style="font-size: 2rem;"></i></div>
  <div class="fw-light">
    Something went wrong.
  </div>
</div>

<img class="rounded mx-auto d-block img-thumbnail mb-3"
  style="height:auto; width:100%; max-height:100%; object-fit:contain; aspect-ratio:1/1; transition: opacity 1000ms ease-in-out;"
  alt="Scan this QR code on your phone to sign in with a credential from Microsoft Authenticator"
  src="data:image/png;base64," />

<div class="alert alert-info d-flex align-items-center" role="alert">
  <div class="text-primary me-3"><i class="bi-info-square text-primary" style="font-size: 2rem;"></i></div>
  <div class="fw-light">
    Scan this QR code on your phone to sign in with a credential from <a
      class="link-primary link-offset-2 link-underline-opacity-25 link-underline-opacity-100-hover"
      href="https://www.microsoft.com/en-au/security/mobile-authenticator-app" target="_blank">Microsoft Authenticator
    </a>.
    <br />The QR code will expire in 5 minutes.
  </div>
</div>

<div class="text-center mb-3"><button type="button" class="btn btn-primary">Present Credential <i
      class="ms-2 bi-arrow-up-right-square"></i></button></div>

<div class="alert alert-info d-flex align-items-center" role="alert">
  <div class="text-primary me-3"><i class="bi-info-square text-primary" style="font-size: 2rem;"></i></div>
  <div class="fw-light">
    Sign in by presenting a credential from <a
      class="link-primary link-offset-2 link-underline-opacity-25 link-underline-opacity-100-hover"
      href="https://www.microsoft.com/en-au/security/mobile-authenticator-app" target="_blank">Microsoft Authenticator
    </a>.
    <br />The QR code will expire in 5 minutes.
  </div>
</div>