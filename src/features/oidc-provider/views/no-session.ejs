<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <title>Sign-in</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous"
        nonce="<%-cspNonce%>">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
        nonce="<%-cspNonce%>">
  <style nonce="<%-cspNonce%>">
    html,
    body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
    }

    body {
      margin-top: 25px;
      margin-bottom: 25px;
      background-color: #FFFFFF
    }

    .login-card {
      padding: 20px 10px;
      padding-bottom: 10px;
      min-width: 250px;
      max-width: 94%;
      background-color: #F7F7F7;
      margin: 10px auto 10px;
      border-radius: 2px;
      box-shadow: 0px 2px 2px rgba(0, 0, 0, 0.3);
      overflow: hidden;
    }

    @media (min-width: 575px) {
      .login-card {
        padding: 30px;
        padding-bottom: 10px;
        width: 500px;
      }
    }

    .login-card+.login-card {
      padding-top: 10px;
    }

    .login-card h1 {
      font-weight: 200;
      text-align: center;
    }

    .login-card .msg {
      font-size: 16px;
      text-align: center;
      padding: 10px;
      margin: 10px 0;
    }

    .logo {
      max-width: 60%;
    }
  </style>
</head>

<body>
  <div class="login-card">
    <div class="d-flex justify-content-center mb-2">
      <img class="logo" src="<%- voLogoUrl %>" alt="VO Logo">
    </div>
    <h1>Oops! We couldn't find your session.</h1>
    <div class="msg">
      This can sometimes happen if it expired or wasn't set up correctly. Please follow your organisation's procedures
      to report this issue if you need further assistance.
    </div>
  </div>
</body>

</html>
