<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <title>Sign-in</title>
  <style nonce="<%-cspNonce%>">
    /* --- Minimal Bootstrap Replacements --- */
    /* for the specific classes used in this layout. */
    @keyframes spinner-border {
      to {
        transform: rotate(360deg);
      }
    }

    h1 {
      font-size: calc(1.375rem + 1.5vw);
    }

    .h1,
    .h2,
    .h3,
    .h4,
    .h5,
    .h6,
    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      margin-top: 0;
      margin-bottom: .5rem;
      font-weight: 500;
      line-height: 1.2;
    }

    .d-none {
      display: none !important;
    }

    .d-flex {
      display: flex !important;
    }

    .d-block {
      display: block !important;
    }

    .align-items-center {
      align-items: center !important;
    }

    .justify-content-center {
      justify-content: center !important;
    }

    .text-center {
      text-align: center !important;
    }

    .mx-auto {
      margin-left: auto !important;
      margin-right: auto !important;
    }

    .ms-auto {
      margin-left: auto !important;
    }

    .me-3 {
      margin-right: 1rem !important;
    }

    .ms-2 {
      margin-left: 0.5rem !important;
    }

    .mb-2 {
      margin-bottom: 0.5rem !important;
    }

    .mb-3 {
      margin-bottom: 1rem !important;
    }

    .my-4 {
      margin-top: 1.5rem !important;
      margin-bottom: 1.5rem !important;
    }

    .fw-light {
      font-weight: 300 !important;
    }

    .text-primary {
      color: #0d6efd !important;
    }

    .text-success {
      color: #198754 !important;
    }

    .text-danger {
      color: #dc3545 !important;
    }

    .alert {
      position: relative;
      padding: 1rem 1rem;
      margin-bottom: 1rem;
      border: 1px solid transparent;
      border-radius: 0.375rem;
    }

    .alert-info {
      color: #055160;
      background-color: #cff4fc;
      border-color: #b6effb;
    }

    .alert-success {
      color: #0f5132;
      background-color: #d1e7dd;
      border-color: #badbcc;
    }

    .alert-danger {
      color: #842029;
      background-color: #f8d7da;
      border-color: #f5c2c7;
    }

    .btn {
      display: inline-block;
      font-weight: 400;
      line-height: 1.5;
      color: #212529;
      text-align: center;
      text-decoration: none;
      vertical-align: middle;
      cursor: pointer;
      user-select: none;
      background-color: transparent;
      border: 1px solid transparent;
      padding: 0.375rem 0.75rem;
      font-size: 1rem;
      border-radius: 0.375rem;
      transition: color 0.15s ease-in-out, background-color 0.15s ease-in-out, border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

    .btn:hover {
      color: #212529;
    }

    .btn-primary {
      color: #fff;
      background-color: #0d6efd;
      border-color: #0d6efd;
    }

    .btn-primary:hover {
      color: #fff;
      background-color: #0b5ed7;
      border-color: #0a58ca;
    }

    .spinner-border {
      display: inline-block;
      width: 2rem;
      height: 2rem;
      vertical-align: -0.125em;
      border: 0.25em solid currentColor;
      border-right-color: transparent;
      border-radius: 50%;
      animation: 0.75s linear infinite spinner-border;
    }

    .spinner-border-md {
      width: 1.5rem;
      height: 1.5rem;
      border-width: 0.2em;
    }

    .rounded {
      border-radius: 0.375rem !important;
    }

    .img-thumbnail {
      padding: 0.25rem;
      background-color: #fff;
      border: 1px solid #dee2e6;
      border-radius: 0.375rem;
      max-width: 100%;
      height: auto;
    }

    a {
      text-decoration: none;
    }

    .link-primary {
      color: #0d6efd;
      text-decoration: underline;
    }

    .link-primary:hover {
      color: #0a58ca;
    }

    .link-secondary {
      color: #6c757d;
      text-decoration: underline;
    }

    .link-secondary:hover {
      color: #565e64;
    }

    .link-offset-2 {
      text-underline-offset: 0.25em;
    }

    .link-underline-opacity-25 {
      text-decoration-color: rgba(108, 117, 125, 0.25);
    }

    .link-primary.link-underline-opacity-25 {
      text-decoration-color: rgba(13, 110, 253, 0.25);
    }

    .link-underline-opacity-100-hover:hover {
      text-decoration-color: inherit;
    }

    .link-opacity-75 {
      opacity: 0.75;
    }

    .link-opacity-100-hover:hover {
      opacity: 1;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
    }

    body {
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue",
        "Noto Sans", "Liberation Sans", Arial, sans-serif, "Apple Color Emoji",
        "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
      margin-top: 25px;
      margin-bottom: 25px;
      background-color: <%=backgroundColor || '#FFFFFF' %>;
      <%- backgroundImageUrl ? `background-image: url('${backgroundImageUrl}');
      background-position: center center;
      background-size: cover;
      background-repeat: no-repeat;
      `: ''
        %>
    }

    #client-logo {
      margin: 0 auto;
      <% if (dropToEs5) { %>
      max-width: 300px;
      width: 100%;
      display: block !important;
      text-align: center;
      <% } %>
    }

    #client-logo img {
      max-width: 100%;
      max-height: 120px;
      <% if (!dropToEs5) { %>
      object-fit: contain;
      <% } else { %>
      display: inline-block;
      width: auto;
      height: auto;
      vertical-align: middle;
      <% } %>
    }

    .login-card {
      padding: 20px 10px;
      padding-bottom: 10px;
      min-width: 250px;
      max-width: 94%;
      background-color: #F7F7F7;
      margin: 10px auto 10px;
      border-radius: 2px;
      box-shadow: 0px 2px 2px rgba(0, 0, 0, 0.3);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    @media (min-width: 575px) {
      .login-card {
        padding: 30px;
        padding-bottom: 10px;
        width: 440px;
      }
    }

    .login-card+.login-card {
      padding-top: 10px;
    }

    .login-info-wrapper {
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }

    .login-content-wrapper {
      display: flex;
      flex-direction: column;
    }

    .login-header-content {
      text-align: center;
    }

    #cancel-btn-horizontal {
      display: none;
    }

    #cancel-btn-vertical {
      display: block;
    }

    #qrCodeCanvas {
      max-width: 430px;
      <% if (!dropToEs5) { %>
      height: auto;
      width: 100%;
      max-height: 100%;
      object-fit: contain;
      aspect-ratio: 1 / 1;
      opacity: 1;
      <% } else { %>
      display: block;
      margin: 0 auto;
      max-height: 430px;
      opacity: 1;
      <% } %>
    }

    <% if (dropToEs5) { %>
    #desktop {
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .login-body-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      box-sizing: border-box;
    }
    <% } %>

    /**
    * Embedded browser in Teams (Win/Mac) that may host this login page
    */
    @media (max-width: 650px) and (max-height: 650px) {
      .login-info-wrapper {
        flex: 0 0 30%;
        max-width: 200px;
      }

      .login-content-wrapper {
        flex: 0 0 70%;
      }
    }

    /* Horizontal layout for when screen height is low  */
    @media (max-height: 900px) {
      #client-logo {
        min-width: 100px;
      }

      #cancel-btn-horizontal {
        display: block;
      }

      #cancel-btn-vertical {
        display: none;
      }

      #qrCodeCanvas {
        <% if (!dropToEs5) { %>
        max-width: min(55vw, 47vh);
        <% } else { %>
        max-width: 55vw;
        <% } %>
        min-width: 100px;
      }

      body {
        margin-top: 5px;
        margin-bottom: 5px;
      }

      .alert {
        margin-bottom: 1rem;
        padding: 0.5rem;
      }

      .login-card {
        flex-direction: row;
        align-items: center;
        max-height: 95vh;
        width: 90vw;
        max-width: 900px;
        padding: 1rem;
      }

      .login-info-wrapper {
        flex: 0 0 40%;
        padding-right: 1.5rem;
        justify-content: center;
        text-align: left;
      }

      .login-header-content {
        text-align: left;
      }

      .login-content-wrapper {
        flex: 0 0 60%;
      }

      .login-footer-content {
        text-align: left;
      }

      .login-body-content {
        padding-left: 1rem;
        padding-right: 1rem;
        border-left: 1px solid #dee2e6;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 63vh;
      }

      .grant-debug,
      .error-debug {
        max-width: 500px;
      }
    }


    .login-card h1 {
      font-size: 2.5rem;
      font-weight: 200;
      text-align: center;
    }

    .login-card h2 {
      font-weight: 400;
      text-align: center;
    }

    .login-card h2.title-sm {
      font-size: 1.4rem;
    }

    .login-card [type=submit] {
      width: 100%;
      display: block;
      margin-bottom: 10px;
      position: relative;
    }

    .login-help {
      color: #666;
      width: 100%;
      text-align: center;
      font-size: 12px;
      margin-top: 1rem;
    }

    .login-help>a~a {
      padding-left: 4px;
    }

    .login-card input[type=checkbox] {
      margin-bottom: 10px;
    }

    .login-card label {
      color: #999;
    }

    .grant-debug,
    .error-debug {
      text-align: center;
      font-family: Fixed, monospace;
      font-size: 12px;
      color: #999;
      min-width: 250px;
      max-width: 50vw;
      margin-left: auto;
      margin-right: auto;
      display: block;
      <% if (!dropToEs5) { %>
      padding-top: 10px;
      <% } else { %>
      margin-bottom: 1rem;
      padding: 10px;
      <% } %>
    }

    #client-errors-debug {
      display: none;
      margin-top: 1rem;
    }

    .debug dt {
      font-weight: bold;
      text-align: left;
    }

    .debug dd {
      margin-bottom: 10px;
      text-align: left;
    }

    .debug details {
      background-color: #f8f9fa;
      border: 1px solid #ced4da;
      border-radius: 5px;
      padding: 10px;
      margin-top: 10px;
    }

    .debug summary {
      cursor: pointer;
      font-weight: bold;
    }

    .login-help+form {
      margin-top: 10px;
    }

    ul {
      font-weight: 100;
      padding-left: 1em;
      list-style-type: circle;
    }

    li+ul,
    ul+li,
    li+li {
      padding-top: 0.3em;
    }

    li>pre {
      font-size: 12px;
      font-family: Fixed, monospace;
      margin: 0px;
    }

    button {
      cursor: pointer;
    }

    .text-center {
      text-align: center;
    }
  </style>
</head>

<% const fontClass = (client?.clientName?.length > 30) ? 'title-sm' : ''; %>

<body>
  <div class="login-card">
    <div class="login-info-wrapper">
      <div class="login-header-content">
        <div id="client-logo" class="logo-wrapper d-flex justify-content-center mb-2">
          <% if (logoUrl) { %>
          <img src="<%- logoUrl %>" alt="<%= client.clientName %>" />
          <% } else { %>
          <img src="<%- voLogoUrl %>" alt="Verified Orchestration Logo" />
          <% } %>
        </div>

        <h1><%= title %></h1>
        <h2 class="<%= fontClass %>"><%= client.clientName %></h2>
      </div>
      <% if(uid) { %>
      <div id="cancel-btn-horizontal" class="text-center">
        <a href="/oidc/interaction/<%= uid %>/abort"
          class="link-secondary link-offset-2 link-opacity-75 link-opacity-100-hover link-underline-opacity-25 link-underline-opacity-100-hover">Cancel</a>
      </div>
      <% } %>
    </div>

    <div class="login-content-wrapper">
      <div class="login-body-content">
        <%- body %>
      </div>

      <div class="login-footer-content">
        <% if(uid) { %>
        <div id="cancel-btn-vertical" class="text-center">
          <a href="/oidc/interaction/<%= uid %>/abort"
            class="link-secondary link-offset-2 link-opacity-75 link-opacity-100-hover link-underline-opacity-25 link-underline-opacity-100-hover">Cancel</a>
        </div>
        <% } %>
        <div class="login-help">
          <% if (client.tosUri) { %>
          <a href="<%= client.tosUri %>" target="_blank"
            class="link-secondary link-offset-2 link-opacity-75 link-opacity-100-hover link-underline-opacity-25 link-underline-opacity-100-hover">Terms
            of Service</a>
          <% } %>
          <% if (client.policyUri) { %>
          <a href="<%= client.policyUri %>" target="_blank"
            class="link-secondary link-offset-2 link-opacity-75 link-opacity-100-hover link-underline-opacity-25 link-underline-opacity-100-hover">Privacy
            Policy</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <% if (showDebug) { %>
  <script nonce="<%-cspNonce%>">
    // Queue to store errors that occur before DOM is ready
    var pendingClientErrors = []

    function showClientError(title, details) {
      var container = document.getElementById('client-errors-debug')
      var list = document.getElementById('client-errors-list')

      if (container && list) {
        container.style.display = 'block'

        var dt = document.createElement('dt')
        dt.textContent = title
        dt.className = 'text-danger'

        var dd = document.createElement('dd')
        for (var key in details) {
          if (details.hasOwnProperty(key)) { // es5 compatibility
            var strong = document.createElement('strong')
            strong.textContent = key + ':'
            dd.appendChild(strong)
            dd.appendChild(document.createTextNode(' ' + details[key]))
            dd.appendChild(document.createElement('br'))
          }
        }

        list.appendChild(dt)
        list.appendChild(dd)
      } else {
        // DOM not ready yet, queue the error for later
        pendingClientErrors.push({ title: title, details: details })
      }
    }

    // Capture unhandled JavaScript errors immediately
    window.onerror = function (message, source, lineno, colno, error) {
      showClientError('JavaScript Error', {
        message: message || 'Unknown error',
        source: (source || 'unknown') + ':' + (lineno || '?') + ':' + (colno || '?'),
        stack: error && error.stack ? error.stack : 'N/A'
      })
      return false // Let default handler run too
    }

    // Capture unhandled promise rejections immediately
    window.addEventListener('unhandledrejection', function (event) {
      var reason = event.reason
      var reasonText = reason == null ? 'Unknown rejection' : String(reason)
      showClientError('Unhandled Promise Rejection', {
        reason: reasonText,
        stack: reason && reason.stack ? reason.stack : 'N/A'
      })
    })

    window.addEventListener('load', function() { // es5 compatibility
      document.getElementById('window-dimensions-debug').innerText = window.innerWidth + ' (w) x ' + window.innerHeight + ' (h)'; // es5 compatibility

      // Display any errors that were queued before DOM was ready
      for (var i = 0; i < pendingClientErrors.length; i++) {
        showClientError(pendingClientErrors[i].title, pendingClientErrors[i].details)
      }
      pendingClientErrors = []

      <% if (dropToEs5 || dropToEs6) { %>
      ;(function() {
        var testDetails = document.createElement('details');
        if ('open' in testDetails) return;

        var detailsElements = document.getElementsByTagName('details');
        for (var i = 0; i < detailsElements.length; i++) {
          var details = detailsElements[i];
          var summaries = details.getElementsByTagName('summary');
          if (summaries.length === 0) continue;
          var summary = summaries[0];

          // Hide content initially if not open
          if (!details.hasAttribute('open')) {
            var children = details.children;
            for (var j = 0; j < children.length; j++) {
              if (children[j] !== summary) {
                children[j].style.display = 'none';
              }
            }
          }

          // Add click handler (using closure to capture details and summary)
          (function(detailsEl, summaryEl) {
            summaryEl.addEventListener('click', function(e) {
              e.preventDefault();
              var isOpen = detailsEl.hasAttribute('open');
              var children = detailsEl.children;

              for (var k = 0; k < children.length; k++) {
                if (children[k] !== summaryEl) {
                  children[k].style.display = isOpen ? 'none' : '';
                }
              }

              if (isOpen) {
                detailsEl.removeAttribute('open');
              } else {
                detailsEl.setAttribute('open', 'open');
              }
            });
          })(details, summary);

          summary.style.cursor = 'pointer';
        }
      })()
      <% } %>
    })
  </script>
  <div class="grant-debug debug">
    <details>
      <summary class="text-center">(Click to expand) DEBUG information</summary>
      <dl>
        <dt>window size</dt>
        <dd id="window-dimensions-debug"></dd>

        <% if(uid) { %>
        <dt>uid</dt>
        <dd><%= uid %></dd>
        <% } %>

        <% if (session) { %>
        <dt>SESSION</dt>
        <dd>
          ========= <br>
          <%- session %>
        </dd>
        <% } %>

        <% if(dbg) { %>
        <dt>PARAMS</dt>
        <dd>
          ======== <br>
          <%- dbg.params %>
        </dd>

        <dt>PROMPT</dt>
        <dd>
          ======== <br>
          <%- dbg.prompt %>
        </dd>
        <% } %>
      </dl>
    </details>
  </div>
  <% } %>
  <% if (showDebug) { %>
  <div id="client-errors-debug" class="grant-debug debug">
    <details open>
      <summary class="text-center text-danger">Client-Side Errors</summary>
      <dl id="client-errors-list"></dl>
    </details>
  </div>
  <% } %>
  <% if (showErrorDebug) { %>
  <div class="error-debug debug">
    <details>
      <summary class="text-center">(Click to expand) ERROR information</summary>
      <div>
        <dl>
          <dt>message</dt>
          <dd><%= error.message %></dd>
          <dt>stack</dt>
          <dd><code><%= error.stack %></code></dd>
          <dt>cause</dt>
          <dd><%= error.cause %></dd>
          <dt>fileName</dt>
          <dd><%= error.fileName %></dd>
          <dt>column #</dt>
          <dd><%= error.column %></dd>
          <dt>line #</dt>
          <dd><%= error.line %></dd>
        </dl>
      </div>
    </details>
  </div>
  <% } %>
</body>

</html>
