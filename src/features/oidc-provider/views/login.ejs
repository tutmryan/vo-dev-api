<script type="text/javascript" nonce="<%-cspNonce%>">
  // Polyfill when missing
  if (typeof Symbol !== 'undefined') {
    if (typeof Symbol.asyncIterator === 'undefined') {
      Symbol.asyncIterator = Symbol.for('Symbol.asyncIterator')
    }
  }

  const isMobile = /Android|iPhone/i.test(navigator.userAgent)

  <% if (!dropToEs5) { %> let <% } else { %> var <% } %> client
  window.onload = function () {
    client = new verifiedOrchestrationClientJs.VerifiedOrchestrationClient({
      url: '<%- graphqlUrl %>',
      accessToken: '<%- presentationAccessToken %>',
    })
      <% if (!dropToEs5) { %> const <% } else { %> var <% } %> request = <%-JSON.stringify(presentationRequest)%>
      client
        .createPresentationRequestForAuthn(request, handlePresentationEvent)
        .then(handlePresentation)
        .catch(displayError)
  }

  function handlePresentation(response) {
    if ('error' in response) {
      displayError(response.error)
      return
    }
    displayPresentationResponse(response)
  }

  function openDeeplink(url) {
    if (!url) return

    if (!/Chrome|Chromium/i.test(navigator.userAgent)) {
      window.location.href = url
      return;
    }

    // If this is a Chromium-based mobile browser, use button to act as a user gesture, which prevents BFCache issues.
    // see: https://issues.chromium.org/issues/40240372
    <% if (!dropToEs5) { %> const <% } else { %> var <% } %> btn = document.createElement('button')
    btn.style.display = 'none'
    btn.onclick = function() { // es5 compatibility
      window.open(url, '_blank', 'noopener,noreferrer')
    }
    document.body.appendChild(btn)

    setTimeout(function() { btn.click() }, 100) // es5 compatibility
  }

  <% if (!dropToEs5) { %>
  function displayPresentationResponse({ requestId, qrCode, url }) {
  <% } else { %>
  function displayPresentationResponse(response) {
    var requestId = response.requestId
    var qrCode = response.qrCode
    var url = response.url
  <% } %>
    document.querySelector('input[name="requestId"]').value = requestId
    if (isMobile) {
      openDeeplink(url)
      displayMobile(url)
    } else {
      displayDesktop(qrCode, url)
    }
    setTimeout(handleTimeout, 5 * 60 * 1000)
  }

  function handlePresentationEvent(data) {
    if (data instanceof Error) {
      displayError(data)
    } else if (data.event.requestStatus === 'presentation_error') {
      <% if (!dropToEs5) { %>
      const { code, message } = data.event.error
      <% } else { %>
      var code = data.event.error.code
      var message = data.event.error.message
      <% } %>
      if (code === 'vcExpiredError') {
        displayError('The Verifiable Credential you presented has expired. Please contact the issuer to obtain a new credential or for further assistance.')
      } else {
        displayError(data.event.error ? code + ': ' + message : 'Presentation failed.')
      }
    } else if (data.event.requestStatus === 'request_retrieved') {
      displayProgress('Scanned, waiting for presentation...')
    } else {
      displayFinish()
      document.querySelector('form').submit();
    }
  }

  function displayMobile(url) {
    hide(document.querySelector('#progress'))
    show(document.querySelector('#mobile'))
    document.querySelector('#openUrl').addEventListener('click', function() { window.location.href = url }) // es5 compatibility
  }

  function displayDesktop(qrCode, url) {
    hide(document.querySelector('#progress'))
    show(document.querySelector('#desktop'))
    displayQrCode(qrCode, url)
  }

  <% if (!dropToEs5) { %>
  function displayQrCode(src, url) {
    const canvas = document.querySelector('#qrCodeCanvas')
    const ctx = canvas.getContext('2d')

    const img = new Image()
    img.onload = () => {
      canvas.width = img.width
      canvas.height = img.height
      ctx.drawImage(img, 0, 0)
    };
    img.src = src
  }
  <% } else { %>
  function displayQrCode(src, url) {
    var canvas = document.querySelector('#qrCodeCanvas')
    var ctx = canvas.getContext('2d')

    var img = new Image()
    img.onload = function() {
      // Calculate the display size - make it square and constrained
      var container = canvas.parentElement
      var maxSize = 350
      var containerWidth = container.offsetWidth
      var displaySize = Math.min(maxSize, containerWidth - 40) // 40px for padding/margins

      // Set both CSS display size and canvas internal size to the same dimensions
      // This prevents stretching and maintains aspect ratio
      canvas.style.width = displaySize + 'px'
      canvas.style.height = displaySize + 'px'
      canvas.width = displaySize
      canvas.height = displaySize

      // Draw the image scaled to fit
      ctx.drawImage(img, 0, 0, displaySize, displaySize)
    }
    img.src = src
  }
  <% } %>

  function handleTimeout() {
    hide(document.querySelectorAll('#desktop, #mobile, #progress'))
    displayError({ message: 'QR code expired, please cancel and try again.' })
  }

  function displayProgress(progress) {
    hide(document.querySelectorAll('#desktop, #mobile, #error, #finish'))
    document.querySelector('#progressText').textContent = progress
    show(document.querySelector('#progress'), 'd-flex')
  }

  function displayFinish() {
    hide(document.querySelector('#progress, #desktop, #mobile, #error'))
    show(document.querySelector('#finish'))
  }

  function displayError(error) {
    hide(document.querySelectorAll('#desktop, #mobile, #progress'))
    <% if (!dropToEs5) { %>
    document.querySelector('#errorText').textContent = `${(error && error.message != null ? error.message : error)}`
    <% } else { %>
    var errorMessage = (error && error.message != null ? error.message : error)
    document.querySelector('#errorText').textContent = String(errorMessage)
    <% } %>
    show(document.querySelector('#error'))
  }

  <% if (!dropToEs5) { %>
  function hide(selectors) {
    if (!selectors.length) selectors = [selectors]
    selectors.forEach(el => {
      el.classList.add('d-none')
      el.classList.remove('d-flex')
    })
  }
  <% } else { %>
  function hide(selectors) {
    // Convert NodeList to Array for IE11 compatibility
    if (!selectors.length) selectors = [selectors]
    var elements = Array.prototype.slice.call(selectors)
    for (var i = 0; i < elements.length; i++) {
      elements[i].classList.add('d-none')
      elements[i].classList.remove('d-flex')
    }
  }
  <% } %>

  <% if (!dropToEs5) { %>
  function show(selectors, displayClass = null) {
    if (!selectors.length) selectors = [selectors]
    selectors.forEach(el => {
      el.classList.remove('d-none')
      if (displayClass) {
        el.classList.add(displayClass)
      }
    })
  }
  <% } else { %>
  function show(selectors, displayClass) {
    // Convert NodeList to Array for IE11 compatibility
    if (!selectors.length) selectors = [selectors]
    var elements = Array.prototype.slice.call(selectors)
    for (var i = 0; i < elements.length; i++) {
      elements[i].classList.remove('d-none')
      if (displayClass) {
        elements[i].classList.add(displayClass)
      }
    }
  }
  <% } %>

</script>

<style nonce="<%-cspNonce%>">
  #scan-guide {
    width: 100%;
    box-sizing: border-box;
  }
  .font2 {
    font-size: 2rem;
  }
</style>

<div id="progress" class="alert alert-info d-flex align-items-center" role="alert">
  <div class="spinner-border spinner-border-md text-primary me-3" role="status"></div>
  <div class="fw-light" id="progressText">
    Generating QR code...
  </div>
</div>

<div id="desktop" class="d-none">
  <canvas
    id="qrCodeCanvas"
    class="rounded mx-auto d-block img-thumbnail mb-3"
  ></canvas>
  <div id="scan-guide" class="alert alert-info d-flex align-items-center" role="alert" aria-live="polite">
    <div class="fw-light">
      <span>Scan this QR code on your phone to sign in with a credential from </span>
      <a
        class="link-primary link-offset-2 link-underline-opacity-25 link-underline-opacity-100-hover"
        href="https://www.microsoft.com/en-au/security/mobile-authenticator-app"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Microsoft Authenticator app (opens in new tab)"
      >Microsoft Authenticator</a>.
      <br />
      <span class="text-muted">The QR code will expire in 5 minutes.</span>
    </div>
  </div>
</div>

<div id="mobile" class="d-none">
  <div class="text-center mb-3"><button id="openUrl" type="button" class="btn btn-primary">Present Credential <i
        class="ms-2 bi-arrow-up-right-square"></i></button></div>
  <div class="alert alert-info d-flex align-items-center" role="alert">
    <div class="text-primary me-3"><i class="bi-info-square text-primary font2"></i></div>
    <div class="fw-light">
      Sign in by presenting a credential from <a
        class="link-primary link-offset-2 link-underline-opacity-25 link-underline-opacity-100-hover"
        href="https://www.microsoft.com/en-au/security/mobile-authenticator-app" target="_blank">Microsoft Authenticator
      </a>.
      <br />The link will expire in 5 minutes.
    </div>
  </div>
</div>

<div id="finish" class="alert alert-success d-flex align-items-center d-none" role="alert">
  <div class="spinner-border spinner-border-md text-primary me-3" role="status"></div>
  <div class="fw-light">
    Presentation received.
    <br />Signing you in...
  </div>
  <div class="ms-auto"></div>
  <div class="text-success me-3"><i class="bi-check2-all text-success font2" ></i></div>
</div>

<div id="error" class="alert alert-danger d-flex align-items-center d-none my-4" role="alert">
  <div class="text-primary me-3"><i class="bi-exclamation-circle text-danger font2"></i></div>
  <div class="fw-light" id="errorText">
  </div>
</div>

<form autocomplete="off" action="/oidc/interaction/<%= uid %>/login" method="post">
  <input type="hidden" name="requestId" />
</form>

<script type="text/javascript" nonce="<%-cspNonce%>">
  displayProgress(isMobile ? 'Generating presentation link...' : 'Generating QR code...')
</script>
<% if (dropToEs5) { %>
<script type="text/javascript" nonce="<%-cspNonce%>"
        src="https://cdn.jsdelivr.net/npm/core-js-bundle@3/minified.js"></script>
<script type="text/javascript" nonce="<%-cspNonce%>"
        src="https://cdn.jsdelivr.net/npm/whatwg-fetch@3/dist/fetch.umd.js"></script>
<script type="text/javascript" nonce="<%-cspNonce%>"
        src="https://cdn.jsdelivr.net/npm/@verified-orchestration/client-js/index.es5.min.js"></script>
<% } else if (dropToEs6) { %>
<script type="text/javascript" nonce="<%-cspNonce%>"
        src="https://cdn.jsdelivr.net/npm/@verified-orchestration/client-js/index.es6.min.js"></script>
<% } else { %>
<script type="text/javascript" nonce="<%-cspNonce%>"
        src="https://cdn.jsdelivr.net/npm/@verified-orchestration/client-js/index.min.js"></script>
<% } %>
