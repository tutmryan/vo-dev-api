{
  "name": "@makerx/migrate-db",
  "version": "1.0.0",
  "description": "Runs TypeORM migrations",
  "author": "MakerX",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "cross-env HOST=localhost DATABASE=VerifiedOrchestration USER=api_user PASSWORD=7o}R~=XA1jmz!-aHQ^pA ts-node --transpile-only -r dotenv/config index",
    "check-types": "tsc --noEmit",
    "audit": "npx --yes better-npm-audit audit",
    "build": "npm run clean && tsc && npm run build:copy-files && npm run build:install && npm run build:post-build",
    "clean": "rimraf build",
    "build:copy-files": "copyfiles \"package*.json\" host.json build",
    "build:install": "npm ci --omit=dev --prefix build",
    "build:post-build": "rimraf build/package-lock.json"
  },
  "devDependencies": {
    "@tsconfig/node18": "^18.2.2",
    "@types/node": "^20.11.17",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "mssql": "^10.0.2",
    "typeorm": "^0.3.20"
  }
}
