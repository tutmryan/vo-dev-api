{
  "name": "@makerx/migrate-db",
  "version": "1.0.0",
  "description": "Runs TypeORM migrations",
  "author": "MakerX",
  "main": "index.js",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "cross-env HOST=localhost DATABASE=VerifiedOrchestration USER=api_user PASSWORD=7o}R~=XA1jmz!-aHQ^pA ts-node --transpile-only -r dotenv/config index",
    "check-types": "tsc --noEmit",
    "audit": "npx --yes better-npm-audit audit",
    "verify-migrations": "ts-node scripts/verify-migrations.ts",
    "build": "npm run clean && tsc && npm run build:copy-files && npm run build:install && npm run build:post-build",
    "clean": "shx rm -rf build",
    "build:copy-files": "shx cp package*.json build",
    "build:install": "npm ci --omit=dev --prefix build",
    "build:post-build": "shx rm build/package-lock.json"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.9",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.2.3",
    "cross-env": "^10.1.0",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "mssql": "^12.2.0",
    "typeorm": "^0.3.28"
  },
  "overrides": {
    "@azure/identity": "^4.3.0",
    "glob": "^12.0.0",
    "sha.js": "^2.4.12",
    "ts-node": {
      "diff": ">=4.0.4"
    }
  }
}
